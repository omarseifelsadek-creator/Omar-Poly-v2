# ──────────────────────────────────────────────────────────────────────
# Omar-Poly-v2 — Environment Variables
# ──────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your values:
#     cp .env.example .env
#
# IMPORTANT:
#   - Paper mode (default) does NOT require any of these.
#   - Dry-run and Live pair trading require all POLY_* variables.
#   - Telegram alerts are optional.
# ──────────────────────────────────────────────────────────────────────

# ── Polymarket Credentials (required for --mode dry-run or --mode live) ──
# Get these from https://polymarket.com → Profile → API Keys
POLY_PRIVATE_KEY=your-eoa-private-key-here
POLY_FUNDER=your-proxy-wallet-address-here
POLY_API_KEY=your-clob-api-key-here
POLY_API_SECRET=your-clob-api-secret-here
POLY_API_PASSPHRASE=your-clob-api-passphrase-here

# ── Telegram Alerts (optional) ──
# Create a bot via @BotFather and grab your chat id via @userinfobot
OBI_TELEGRAM_TOKEN=
OBI_TELEGRAM_CHAT_ID=
